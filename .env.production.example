# ─────────────────────────────────────────────────────────────────────────
# Property Basket — Production environment template
# Copy to .env on the server, fill in real values, NEVER commit .env itself.
# Generate APP_KEY with:  php artisan key:generate
# ─────────────────────────────────────────────────────────────────────────

# ── Core ────────────────────────────────────────────────────────────────
APP_NAME="Property Basket"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://propertybasket.co.za
APP_TIMEZONE=Africa/Johannesburg
APP_LOCALE=en_ZA
APP_FALLBACK_LOCALE=en

# Force HTTPS even behind a load-balancer / proxy
APP_FORCE_HTTPS=true

# ── Logging ─────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=daily,stderr
LOG_LEVEL=warning
LOG_DEPRECATIONS_CHANNEL=null
# When using Sentry / Bugsnag, add their channel here:
# SENTRY_LARAVEL_DSN=https://...@sentry.io/...
# SENTRY_TRACES_SAMPLE_RATE=0.2

# ── Database (MySQL 8 or MariaDB 10.6+) ─────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=property_basket
DB_USERNAME=propertybasket
DB_PASSWORD=          # strong random, store in vault

# ── Cache, sessions, queue ──────────────────────────────────────────────
# Production MUST use redis (or memcached) for cache + sessions for
# multi-server scaling and faster invalidation.
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

QUEUE_CONNECTION=redis
# Notifications + PDF attachment rendering must run on a queue worker in prod
# so user-facing requests don't block. Run: php artisan queue:work --tries=3

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_SESSION_DB=2
REDIS_QUEUE_DB=3

# ── Mail (production SMTP) ──────────────────────────────────────────────
# Pick one — Resend / Postmark / SES / Mailgun / SMTP.
MAIL_MAILER=resend
RESEND_API_KEY=
# OR for SMTP:
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.eu.mailgun.org
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=tls

MAIL_FROM_ADDRESS=no-reply@propertybasket.co.za
MAIL_FROM_NAME="${APP_NAME}"

# ── File storage (S3 for production) ────────────────────────────────────
# Local disk is fine for single-server demos; production must use S3
# so multiple app servers + queue workers share storage.
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=af-south-1            # Cape Town
AWS_BUCKET=propertybasket-prod
AWS_URL=https://propertybasket-prod.s3.af-south-1.amazonaws.com
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Paystack (LIVE keys) ────────────────────────────────────────────────
# Get from https://dashboard.paystack.com/#/settings/developer
PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxx
PAYSTACK_BASE_URL=https://api.paystack.co
PAYSTACK_STUB=false
PAYSTACK_CALLBACK_URL=https://propertybasket.co.za/payments/paystack/callback
# Don't forget to set the webhook in the Paystack dashboard:
#   https://propertybasket.co.za/webhooks/paystack

# ── Inertia + Vite ─────────────────────────────────────────────────────
ASSET_URL=                  # leave blank to use APP_URL; set CDN host if using
VITE_APP_NAME="${APP_NAME}"

# ── Trusted proxies (for load-balancer / CDN headers) ──────────────────
# Use '*' if behind a single trusted LB; or a CIDR list.
TRUSTED_PROXIES=*

# ── Telescope / Pulse / Nightwatch (keep DISABLED in production) ───────
TELESCOPE_ENABLED=false
PULSE_ENABLED=false
NIGHTWATCH_ENABLED=false

# ── Broadcasting (optional — for real-time messaging) ──────────────────
BROADCAST_CONNECTION=log
# When enabling Pusher / Soketi:
# BROADCAST_CONNECTION=pusher
# PUSHER_APP_ID=
# PUSHER_APP_KEY=
# PUSHER_APP_SECRET=
# PUSHER_APP_CLUSTER=eu
